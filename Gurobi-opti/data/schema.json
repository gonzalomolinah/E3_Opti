{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "blood-distribution-instance.schema.json",
  "title": "Blood distribution optimization instance",
  "type": "object",
  "required": [
    "metadata",
    "sets",
    "parameters"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "synthetic",
        "description"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "synthetic": {
          "type": "boolean",
          "const": true
        },
        "description": {
          "type": "string"
        }
      }
    },
    "sets": {
      "type": "object",
      "required": [
        "H",
        "G",
        "T",
        "L",
        "U",
        "N",
        "C"
      ],
      "additionalProperties": false,
      "properties": {
        "H": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "G": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "T": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "L": {
          "type": "integer",
          "minimum": 1
        },
        "U": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "N": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2,
          "uniqueItems": true,
          "contains": {
            "const": "0"
          }
        },
        "C": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "donor",
              "receiver"
            ],
            "additionalProperties": false,
            "properties": {
              "donor": {
                "type": "string"
              },
              "receiver": {
                "type": "string"
              }
            }
          },
          "uniqueItems": true
        }
      }
    },
    "parameters": {
      "type": "object",
      "required": [
        "demand",
        "donations",
        "initial_inventory",
        "storage_capacity",
        "travel_time",
        "shortage_penalty",
        "expiration_penalty",
        "compatibility",
        "use_penalty",
        "big_m",
        "max_transport"
      ],
      "additionalProperties": false,
      "properties": {
        "demand": {
          "description": "d[h,g,t], one record for every H x G x T.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/hgt_value"
          }
        },
        "donations": {
          "description": "b[g,t], one record for every G x T.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/gt_value"
          }
        },
        "initial_inventory": {
          "description": "I0[n,g], one record for every N x G. Inventory is assumed to have useful life L.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ng_value"
          }
        },
        "storage_capacity": {
          "description": "K[n], one record for every N.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/n_value"
          }
        },
        "travel_time": {
          "description": "tau[h], one record for every H.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/h_int_value"
          }
        },
        "shortage_penalty": {
          "description": "p.",
          "type": "number",
          "minimum": 0
        },
        "expiration_penalty": {
          "description": "eta.",
          "type": "number",
          "minimum": 0
        },
        "compatibility": {
          "description": "c[g,g'], one record for every G x G.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/gg_binary_value"
          }
        },
        "use_penalty": {
          "description": "alpha[g], one record for every G.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/g_value"
          }
        },
        "big_m": {
          "description": "M.",
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_transport": {
          "description": "Q[t], one record for every T.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/t_value"
          }
        }
      }
    }
  },
  "$defs": {
    "nonnegative_value": {
      "type": "number",
      "minimum": 0
    },
    "hgt_value": {
      "type": "object",
      "required": [
        "h",
        "g",
        "t",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "h": {
          "type": "string"
        },
        "g": {
          "type": "string"
        },
        "t": {
          "type": "integer",
          "minimum": 1
        },
        "value": {
          "$ref": "#/$defs/nonnegative_value"
        }
      }
    },
    "gt_value": {
      "type": "object",
      "required": [
        "g",
        "t",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "g": {
          "type": "string"
        },
        "t": {
          "type": "integer",
          "minimum": 1
        },
        "value": {
          "$ref": "#/$defs/nonnegative_value"
        }
      }
    },
    "ng_value": {
      "type": "object",
      "required": [
        "n",
        "g",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "n": {
          "type": "string"
        },
        "g": {
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/nonnegative_value"
        }
      }
    },
    "n_value": {
      "type": "object",
      "required": [
        "n",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "n": {
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/nonnegative_value"
        }
      }
    },
    "h_int_value": {
      "type": "object",
      "required": [
        "h",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "h": {
          "type": "string"
        },
        "value": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "gg_binary_value": {
      "type": "object",
      "required": [
        "donor",
        "receiver",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "donor": {
          "type": "string"
        },
        "receiver": {
          "type": "string"
        },
        "value": {
          "type": "integer",
          "enum": [
            0,
            1
          ]
        }
      }
    },
    "g_value": {
      "type": "object",
      "required": [
        "g",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "g": {
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/nonnegative_value"
        }
      }
    },
    "t_value": {
      "type": "object",
      "required": [
        "t",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "t": {
          "type": "integer",
          "minimum": 1
        },
        "value": {
          "$ref": "#/$defs/nonnegative_value"
        }
      }
    }
  }
}
